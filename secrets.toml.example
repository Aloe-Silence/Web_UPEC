# Example Streamlit Community Cloud secrets.
#
# In Streamlit Community Cloud:
#   Advanced settings -> Secrets
# Paste one of the following variables.

# Recommended:
PYSMILE_LICENSE_B64 = "PASTE_BASE64_LICENSE_HERE"
PYSMILE_LICENSE_KEY = "PASTE_COMMA_SEPARATED_LICENSE_KEY_HERE"

# Alternative, only if you prefer to paste the raw license text:
# PYSMILE_LICENSE = """PASTE_RAW_LICENSE_TEXT_HERE"""
# PYSMILE_LICENSE_KEY = "PASTE_COMMA_SEPARATED_LICENSE_KEY_HERE"
